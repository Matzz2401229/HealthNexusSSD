# =====================================================================
# HealthNexus — environment template (SDR3)
# Copy to `.env` and fill real values. NEVER commit the real .env.
# Secrets (DB creds, session secret, keys) are env-only — never hardcoded.
# =====================================================================

# --- Node backend ---
NODE_ENV=development
BACKEND_PORT=8080

# --- MySQL ---
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=healthnexus
# Application DB user is limited to SELECT/INSERT/UPDATE only (D1 §9.6)
MYSQL_USER=healthnexus_app
MYSQL_PASSWORD=change_me_app_password
# Root password only used by the container at init time
MYSQL_ROOT_PASSWORD=change_me_root_password

# --- Session / crypto ---
# >= 32 random bytes. Generate: openssl rand -hex 32
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_32
# bcrypt work factor (>=12 recommended)
BCRYPT_ROUNDS=12
# Session timeouts (minutes)
SESSION_IDLE_TIMEOUT_MIN=15
SESSION_ABSOLUTE_TIMEOUT_HR=8

# --- Brute-force protection (D1 §9.1) ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- File upload (D1 §9.4) ---
UPLOAD_MAX_BYTES=10485760      # 10 MB
# Stored OUTSIDE the web root; served only via authenticated endpoints
UPLOAD_DIR=/var/healthnexus/uploads

# --- External OTP / email verification service (D1 DFD) ---
OTP_SERVICE_URL=
OTP_SERVICE_API_KEY=

# --- Frontend ---
FRONTEND_API_BASE_URL=https://localhost/api
